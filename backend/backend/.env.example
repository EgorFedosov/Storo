Authentication__Google__ClientId=your-google-client-id.apps.googleusercontent.com
Authentication__Google__ClientSecret=your-google-client-secret
Authentication__GitHub__ClientId=your-github-client-id
Authentication__GitHub__ClientSecret=your-github-client-secret
Auth__ExternalProviders__0=google
Auth__ExternalProviders__1=github
ConnectionStrings__Postgres=Host=your-render-host;Port=5432;Database=your-db;Username=your-user;Password=your-password;SSL Mode=Require;Trust Server Certificate=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_BUCKET=inventory-images
SUPABASE_PUBLIC_KEY=your-supabase-public-key
SUPABASE_SECRET_KEY=your-supabase-service-role-key
SUPABASE_DEFAULT_LIST_LIMIT=100
SUPABASE_MAX_UPLOAD_SIZE_BYTES=10485760
